
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Branch {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique // e.g., "MAIN", "NORTH", "SOUTH"
  address     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  
  // Relations
  students    Student[]
  teachers    Teacher[]
  classes     Class[]
  academicYears AcademicYear[]
  feeStructures FeeStructure[]
  users       User[]
  certificates Certificate[]
  payments    Payment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AcademicYear {
  id          String   @id @default(cuid())
  name        String   // e.g., "2024-25"
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(false)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  enrollments StudentEnrollment[]
  fees        Fee[]
  attendance  Attendance[]
  certificates Certificate[]
  feeStructures FeeStructure[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([name, branchId])
}

model Student {
  id          String   @id @default(cuid())
  admissionNo String   @unique
  firstName   String
  lastName    String
  dob         DateTime
  gender      String
  address     String?
  phone       String?
  phone2      String?
  email       String?  @unique
  parentName  String?
  motherName  String?
  aadharNo    String?
  penNo       String?
  apaarId     String?
  religion    String?
  classId     String
  class       Class    @relation(fields: [classId], references: [id])
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  attendance  Attendance[]
  fees        Fee[]
  enrollments StudentEnrollment[]
  certificates Certificate[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StudentEnrollment {
  id              String       @id @default(cuid())
  studentId       String
  student         Student      @relation(fields: [studentId], references: [id])
  classId         String
  class           Class        @relation(fields: [classId], references: [id])
  academicYearId  String
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])
  status          String       @default("ACTIVE") // ACTIVE, PROMOTED, TRANSFERRED, WITHDRAWN
  rollNumber      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([studentId, academicYearId])
}

model Certificate {
  id              String       @id @default(cuid())
  certificateNo   String       @unique
  type            String       // BONAFIDE, STUDY_CERTIFICATE, TRANSFER_CERTIFICATE
  studentId       String
  student         Student      @relation(fields: [studentId], references: [id])
  academicYearId  String
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])
  branchId        String?
  branch          Branch?      @relation(fields: [branchId], references: [id])
  issueDate       DateTime     @default(now())
  purpose         String?      // For bonafide certificates
  remarks         String?
  issuedBy        String?      // Staff name
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Teacher {
  id         String              @id @default(cuid())
  employeeId String?             @unique // For Biometric Device ID mapping
  firstName  String
  lastName   String
  email      String              @unique
  phone      String?
  subject    String?
  portalPassword String?         // bcrypt-hashed password for payroll portal login
  branchId   String?
  branch     Branch?             @relation(fields: [branchId], references: [id])
  classes    Class[]
  salaries   TeacherSalary[]
  attendance TeacherAttendance[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

model Class {
  id        String    @id @default(cuid())
  name      String
  section   String?   @map("grade")
  teacherId String?
  teacher   Teacher?  @relation(fields: [teacherId], references: [id])
  branchId  String?
  branch    Branch?   @relation(fields: [branchId], references: [id])
  students  Student[]
  enrollments StudentEnrollment[]
  feeStructures FeeStructure[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Attendance {
  id             String       @id @default(cuid())
  date           DateTime
  status         String       // PRESENT, ABSENT, LATE
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model TeacherAttendance {
  id        String   @id @default(cuid())
  date      DateTime
  status    String   // PRESENT, ABSENT, HALF_DAY, PAID_LEAVE, UNPAID_LEAVE
  
  checkIn   DateTime?
  checkOut  DateTime?
  lateMinutes Int    @default(0)
  isLate    Boolean  @default(false)
  workedHours Float  @default(0)
  
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([teacherId, date])
}


model Fee {
  id              String        @id @default(cuid())
  amount          Float
  originalAmount  Float         @default(0)
  discountAmount  Float         @default(0)
  discountReason  String?
  paidAmount      Float         @default(0)
  dueDate         DateTime
  type            String        // TUITION, TRANSPORT, etc.
  status          String        // PAID, PENDING, OVERDUE
  studentId       String
  student         Student       @relation(fields: [studentId], references: [id])
  academicYearId  String?
  academicYear    AcademicYear? @relation(fields: [academicYearId], references: [id])
  feeStructureId  String?
  feeStructure    FeeStructure? @relation(fields: [feeStructureId], references: [id])
  payments        Payment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Payment {
  id                String   @id @default(cuid())
  receiptNo         String?  @unique  // null for failed transactions
  amount            Float
  date              DateTime @default(now())
  method            String   // CASH, CARD, ONLINE
  status            String   @default("SUCCESS") // SUCCESS, FAILED, CANCELLED
  hdfcStatus        String?  // raw status from HDFC: CHARGED, AUTHORIZATION_FAILED, etc.
  feeId             String?  // nullable — failed txn may have no fee update
  fee               Fee?     @relation(fields: [feeId], references: [id])
  branchId          String?
  branch            Branch?  @relation(fields: [branchId], references: [id])
  hdfcOrderId       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model FeeStructure {
  id             String        @id @default(cuid())
  name           String        // e.g., "Class 1 Annual Fee"
  classId        String?
  class          Class?        @relation(fields: [classId], references: [id])
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id])
  
  registrationFee Float        @default(0)
  tuitionFee     Float         @default(0)
  sportsFee      Float         @default(0)
  booksFee       Float         @default(0)
  uniformFee     Float         @default(0)
  transportFee   Float         @default(0)
  
  totalFee       Float         // Calculated total
  
  installments   Int           @default(1) // Number of installments
  lateFeePerDay  Float         @default(0)
  
  isActive       Boolean       @default(true)
  fees           Fee[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model SchoolSettings {
  id                    String   @id @default(cuid())
  
  // School Info
  schoolName            String   @default("Sprout School")
  address               String?
  phone                 String?
  email                 String?
  website               String?
  
  // Principal Info
  principalName         String?
  principalSignature    String?  // File path
  
  // Branding
  logoUrl               String?
  schoolSeal            String?
  
  // Receipt Settings
  receiptHeader         String?
  receiptFooter         String?
  receiptTerms          String?
  
  // Certificate Settings
  certificateLetterhead String?
  
  // Payroll & Attendance Settings
  lateGracePeriod       Int      @default(15) // minutes
  latePenaltyCount      Int      @default(3)  // 3 late marks = 1 day deduction
  fullDayWorkHours      Float    @default(8)
  halfDayWorkHours      Float    @default(4)
  
  updatedAt             DateTime @updatedAt
  
  @@map("school_settings")
}

model TeacherSalary {
  id            String          @id @default(cuid())
  teacherId     String
  teacher       Teacher         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  basicSalary   Float
  allowances    Float           @default(0)
  deductions    Float           @default(0)
  netSalary     Float
  
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean         @default(true)
  
  payments      SalaryPayment[]
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model SalaryPayment {
  id            String        @id @default(cuid())
  salaryId      String
  salary        TeacherSalary @relation(fields: [salaryId], references: [id], onDelete: Cascade)
  
  month         Int
  year          Int
  
  amount        Float
  leaveDays     Int           @default(0)
  leaveDeduction Float        @default(0)
  finalAmount   Float
  
  status        String        @default("PENDING")
  paymentDate   DateTime?
  paymentMethod String?
  referenceNo   String?
  remarks       String?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@unique([salaryId, month, year])
}

enum Role {
  MANAGEMENT
  ADMIN
  TEACHER
}

model User {
  id              String   @id @default(cuid())
  username        String   @unique
  password        String
  role            Role     @default(ADMIN)
  defaultBranchId String?
  defaultBranch   Branch?  @relation(fields: [defaultBranchId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Backup {
  id        String   @id @default(cuid())
  filename  String
  size      Int      // in bytes
  createdBy String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  performedBy  String   // username
  userId       String?  // user id at time of action
  action       String   // e.g. FEE_PAYMENT_RECORDED
  category     String   // FEE | SALARY | STUDENT | ADMIN | FEE_STRUCTURE
  description  String   // human-readable summary
  meta         Json?    // extra details: amounts, ids, names, before/after
  branchId     String?
  createdAt    DateTime @default(now())

  @@index([performedBy])
  @@index([category])
  @@index([createdAt])
}

model OtpRecord {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
}

model SmsLog {
  id           String   @id @default(cuid())
  type         String   // REGISTRATION, FEE_COLLECTED, FEE_REMINDER, NOTICE, OTP
  recipient    String   // phone number
  message      String
  status       String   // SENT, FAILED, PENDING
  errorMessage String?
  branchId     String?
  sentBy       String?  // admin user id (null = system auto)
  createdAt    DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

// Server-side storage for pending HDFC payments (backup for localStorage)
model PendingPayment {
  id         String   @id @default(cuid())
  orderId    String   @unique
  nonce      String?  @unique  // One-time token — rejects replayed session requests
  studentId  String
  payments   String   // JSON: [{feeId, amount}]
  amount     Float
  status     String   @default("PENDING") // PENDING, COMPLETED, FAILED, EXPIRED
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([studentId])
  @@index([status])
}
